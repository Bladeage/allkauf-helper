{
  "name": "alkauf-fertighaus-helper-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend für den Fertighaus-Helfer (Express + Prisma + PostgreSQL)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "node src/prisma/seed.js",
    "reset-password": "node src/scripts/resetPassword.js",
    "disable-2fa": "node src/scripts/disable2fa.js",
    "test": "vitest run"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.1",
    "otplib": "^13.4.1",
    "pdfkit": "^0.19.1",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
