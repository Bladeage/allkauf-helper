# ============================================================
#  Fertighaus-Helfer — Umgebungsvariablen
#  Kopiere diese Datei nach  .env  und trage echte Werte ein.
#  .env wird NICHT committet (siehe .gitignore).
# ============================================================

# --- Datenbank (PostgreSQL) ---
DB_PASSWORD=change-me-strong-db-password

# --- Auth (JWT) ---
# Langer Zufalls-String, z. B. erzeugen mit:  openssl rand -base64 48
# Wird auch zur Verschlüsselung der 2FA-Secrets verwendet -> nicht nachträglich ändern.
JWT_SECRET=change-me-very-long-random-string
# Session-Dauer ohne "eingeloggt bleiben"; mit Haken gilt JWT_REMEMBER_EXPIRES_IN.
JWT_EXPIRES_IN=7d
# JWT_REMEMBER_EXPIRES_IN=30d

# --- ProtonMail SMTP (E-Mail-Erinnerungen) ---
# Server/Port sind in docker-compose.yml fest: smtp.protonmail.ch:587 (STARTTLS).
# PROTON_SMTP_PASSWORD ist der in der Proton-Weboberfläche erzeugte SMTP-Token.
PROTON_SMTP_USER=erinnerung@deinedomain.de
PROTON_SMTP_PASSWORD=change-me-proton-smtp-token

# --- Empfänger der Erinnerungs-Mails (kommagetrennt) ---
MAIL_TO=fabian@deinedomain.de,partnerin@deinedomain.de

# --- Reminder-Vorlauf in Tagen (Standard 7) ---
REMINDER_LOOKAHEAD_DAYS=7

# --- Basis-URL der App (für Links in den E-Mails). Eure Domain oder http://<host>:8081 ---
APP_URL=https://haus.deinedomain.de

# --- CORS: erlaubte Origins (kommagetrennt). Prod ist same-origin -> LEER lassen.
#     Nur setzen, wenn ein echter Cross-Origin-Client zugreift (z. B. lokale Dev: http://localhost:5173) ---
CORS_ORIGIN=

# --- Feature-Flag: experimentelles Haus-Planungsmodul (true/false) ---
ENABLE_HOUSE_MODULE=true

# --- Datei-/Foto-Anhänge: max. Größe je Datei in MB (Standard 15) ---
MAX_UPLOAD_MB=15

# --- Eingebaute Datensicherung ---
# Läuft ohne weiteres Zutun: sichert Datenbank + Anhänge in ein eigenes Volume.
# Ausschalten nur, wenn du bereits anderweitig sicherst (z. B. Snapshots auf ZFS/Proxmox).
BACKUP_ENABLED=true
# Zeitplan in Cron-Syntax (Europe/Berlin). Standard: täglich 03:30 Uhr.
BACKUP_CRON=30 3 * * *
# Aufbewahrung in Tagen; 0 = nie automatisch löschen.
# Faustregel Platzbedarf: (Größe deiner Anhänge) x BACKUP_RETENTION_DAYS.
BACKUP_RETENTION_DAYS=14

# --- Seed-Datensatz: leer = 'custom' bevorzugt (falls vorhanden), sonst 'generic' ---
SEED_DATASET=

# --- Nutzer ---
# Es werden KEINE Nutzer über .env angelegt. Beim ersten Start der WebUI führt eine
# Onboarding-Seite durch das Anlegen des ersten Admin-Accounts; weitere Nutzer legt
# der Admin anschließend in der App (Bereich "Nutzer") an.

# --- SSO / OIDC (Authentik) — optional ---
# OIDC_ENABLED aktiviert den "Mit Authentik anmelden"-Button. Lokales Login bleibt als Fallback.
# OIDC_ENABLED=true
# OIDC_ISSUER=https://auth.example.com/application/o/<application-slug>/
# OIDC_CLIENT_ID=<aus dem Authentik-Provider>
# OIDC_CLIENT_SECRET=<aus dem Authentik-Provider>
# OIDC_REDIRECT_URI=https://<app-domain>/api/auth/oidc/callback
# OIDC_ALLOW_SIGNUP=true   # neue Authentik-Nutzer automatisch anlegen (per E-Mail gemappt)
# OIDC_SHOW_PASSWORD_LOGIN=true      # false = Login-Screen zeigt NUR OpenID (Passwort-Login per ?local=1 erreichbar)
# OIDC_REQUIRE_VERIFIED_EMAIL=false  # true = nur verknüpfen/anlegen, wenn Authentik die E-Mail als verifiziert meldet (Impersonations-Schutz)
# OIDC_PROMPT=            # leer = nahtloses SSO (empfohlen hinter einem Forward-Auth-Tor); 'login' = erzwingt Neuanmeldung (Betrieb ohne Tor)
