# ============================================================
#  allkauf Fertighaus-Helfer — Umgebungsvariablen
#  Kopiere diese Datei nach  .env  und trage echte Werte ein.
#  .env wird NICHT committet (siehe .gitignore).
# ============================================================

# --- Datenbank (PostgreSQL) ---
DB_PASSWORD=change-me-strong-db-password

# --- Auth (JWT) ---
# Langer Zufalls-String, z. B. erzeugen mit:  openssl rand -base64 48
JWT_SECRET=change-me-very-long-random-string
JWT_EXPIRES_IN=12h

# --- ProtonMail SMTP (E-Mail-Erinnerungen) ---
# Server/Port sind in docker-compose.yml fest: smtp.protonmail.ch:587 (STARTTLS).
# PROTON_SMTP_PASSWORD ist der in der Proton-Weboberfläche erzeugte SMTP-Token.
PROTON_SMTP_USER=erinnerung@deinedomain.de
PROTON_SMTP_PASSWORD=change-me-proton-smtp-token

# --- Empfänger der Erinnerungs-Mails (kommagetrennt) ---
MAIL_TO=fabian@deinedomain.de,partnerin@deinedomain.de

# --- Reminder-Vorlauf in Tagen (Standard 7) ---
REMINDER_LOOKAHEAD_DAYS=7

# --- Basis-URL der App (für Links in den E-Mails). Eure Domain oder http://<host>:8081 ---
APP_URL=https://haus.deinedomain.de

# --- CORS: erlaubte Origins (kommagetrennt). Im Prod-Betrieb same-origin -> meist nur Dev nötig ---
CORS_ORIGIN=http://localhost:5173

# --- Feature-Flag: experimentelles Haus-Planungsmodul (true/false) ---
ENABLE_HOUSE_MODULE=true

# --- Seed: zwei Nutzer-Accounts (werden beim ersten Start angelegt) ---
SEED_USER1_NAME=Fabian
SEED_USER1_EMAIL=fabian@deinedomain.de
SEED_USER1_PASSWORD=change-me-login-password-1
SEED_USER2_NAME=Partnerin
SEED_USER2_EMAIL=partnerin@deinedomain.de
SEED_USER2_PASSWORD=change-me-login-password-2
